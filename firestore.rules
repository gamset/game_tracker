rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Simple family-game rules.
    // Anyone with the game code can read and write that game's data.
    // For a private or public app, add Firebase Authentication and stricter rules.

    match /games/{gameId} {
      allow read, create, update: if true;

      match /players/{playerId} {
        allow read, create, update: if true;
      }

      match /activity/{activityId} {
        allow read, create: if true;
        allow update, delete: if false;
      }
    }
  }
}
